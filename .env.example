# ============================================================
# App
# ============================================================
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ============================================================
# PostgreSQL
# ============================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cert_management
DB_USER=postgres
DB_PASSWORD=

# ============================================================
# Session
# ============================================================
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=

# ============================================================
# Google OAuth (untuk login user)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ============================================================
# Google Drive Service Account (untuk operasi Drive)
# Untuk GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY:
# - Salin seluruh isi private key dari file JSON service account
# - Ganti newline asli dengan literal \n
# - Contoh: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
# ============================================================
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_DRIVE_ROOT_FOLDER_ID=